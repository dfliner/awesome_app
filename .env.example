# copy to .env and adjust values as needed
# This file is used to set environment variables for the application.
# It is not meant to be committed to version control.

# App settings
APP_ENV=development
APP_PORT=8000

# PostgreSQL settings
POSTGRES_DB=awesomeapp
POSTGRES_USER=awesomeuser
POSTGRES_PASSWORD=supersecret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy URL
DATABASE_URL=postgresql+asyncpg://awesomeuser:supersecret@db:5432/awesomeapp

# Secret key
SECRET_KEY=super-secret
DEBUG=true
